<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.daliansea.ai.system.mapper.SeaVesselMapper">

    <resultMap type="SeaVessel" id="SeaVesselResult">
        <id     property="vesselId"     column="vessel_id"     />
        <result property="tenantId"     column="tenant_id"     />
        <result property="tenantName"   column="tenant_name"   />
        <result property="vesselCode"   column="vessel_code"   />
        <result property="vesselName"   column="vessel_name"   />
        <result property="vesselType"   column="vessel_type"   />
        <result property="capacity"     column="capacity"      />
        <result property="homePort"     column="home_port"     />
        <result property="captainName"  column="captain_name"  />
        <result property="captainPhone" column="captain_phone" />
        <result property="serviceArea"  column="service_area"  />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectVesselVo">
        select v.vessel_id, v.tenant_id, t.tenant_name, v.vessel_code, v.vessel_name, v.vessel_type,
               v.capacity, v.home_port, v.captain_name, v.captain_phone, v.service_area, v.status,
               v.create_by, v.create_time, v.update_by, v.update_time, v.remark
        from sea_vessel v
        left join sea_tenant t on v.tenant_id = t.tenant_id
    </sql>

    <select id="selectVesselList" parameterType="SeaVessel" resultMap="SeaVesselResult">
        <include refid="selectVesselVo"/>
        <where>
            <if test="tenantId != null">
                AND v.tenant_id = #{tenantId}
            </if>
            <if test="vesselCode != null and vesselCode != ''">
                AND v.vessel_code like concat('%', #{vesselCode}, '%')
            </if>
            <if test="vesselName != null and vesselName != ''">
                AND v.vessel_name like concat('%', #{vesselName}, '%')
            </if>
            <if test="vesselType != null and vesselType != ''">
                AND v.vessel_type = #{vesselType}
            </if>
            <if test="status != null and status != ''">
                AND v.status = #{status}
            </if>
        </where>
        order by v.vessel_id desc
    </select>

    <select id="selectVesselById" parameterType="Long" resultMap="SeaVesselResult">
        <include refid="selectVesselVo"/>
        where v.vessel_id = #{vesselId}
    </select>

    <select id="countVesselByTenantId" parameterType="Long" resultType="int">
        select count(1) from sea_vessel where tenant_id = #{tenantId}
    </select>

    <select id="checkVesselCodeUnique" parameterType="String" resultMap="SeaVesselResult">
        <include refid="selectVesselVo"/>
        where v.vessel_code = #{vesselCode} limit 1
    </select>

    <insert id="insertVessel" parameterType="SeaVessel" useGeneratedKeys="true" keyProperty="vesselId">
        insert into sea_vessel(
            <if test="tenantId != null">tenant_id,</if>
            <if test="vesselCode != null and vesselCode != ''">vessel_code,</if>
            <if test="vesselName != null and vesselName != ''">vessel_name,</if>
            <if test="vesselType != null and vesselType != ''">vessel_type,</if>
            <if test="capacity != null">capacity,</if>
            <if test="homePort != null and homePort != ''">home_port,</if>
            <if test="captainName != null and captainName != ''">captain_name,</if>
            <if test="captainPhone != null and captainPhone != ''">captain_phone,</if>
            <if test="serviceArea != null and serviceArea != ''">service_area,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="tenantId != null">#{tenantId},</if>
            <if test="vesselCode != null and vesselCode != ''">#{vesselCode},</if>
            <if test="vesselName != null and vesselName != ''">#{vesselName},</if>
            <if test="vesselType != null and vesselType != ''">#{vesselType},</if>
            <if test="capacity != null">#{capacity},</if>
            <if test="homePort != null and homePort != ''">#{homePort},</if>
            <if test="captainName != null and captainName != ''">#{captainName},</if>
            <if test="captainPhone != null and captainPhone != ''">#{captainPhone},</if>
            <if test="serviceArea != null and serviceArea != ''">#{serviceArea},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateVessel" parameterType="SeaVessel">
        update sea_vessel
        <set>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="vesselCode != null and vesselCode != ''">vessel_code = #{vesselCode},</if>
            <if test="vesselName != null and vesselName != ''">vessel_name = #{vesselName},</if>
            <if test="vesselType != null and vesselType != ''">vessel_type = #{vesselType},</if>
            <if test="capacity != null">capacity = #{capacity},</if>
            <if test="homePort != null">home_port = #{homePort},</if>
            <if test="captainName != null">captain_name = #{captainName},</if>
            <if test="captainPhone != null">captain_phone = #{captainPhone},</if>
            <if test="serviceArea != null">service_area = #{serviceArea},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where vessel_id = #{vesselId}
    </update>

    <delete id="deleteVesselById" parameterType="Long">
        delete from sea_vessel where vessel_id = #{vesselId}
    </delete>

    <delete id="deleteVesselByIds" parameterType="Long">
        delete from sea_vessel where vessel_id in
        <foreach collection="array" item="vesselId" open="(" separator="," close=")">
            #{vesselId}
        </foreach>
    </delete>

</mapper>
