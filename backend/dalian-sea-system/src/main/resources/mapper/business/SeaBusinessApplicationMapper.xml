<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.daliansea.ai.system.mapper.SeaBusinessApplicationMapper">

    <resultMap type="SeaBusinessApplication" id="SeaBusinessApplicationResult">
        <id     property="applicationId"   column="application_id"   />
        <result property="tenantId"        column="tenant_id"        />
        <result property="tenantName"      column="tenant_name"      />
        <result property="vesselId"        column="vessel_id"        />
        <result property="vesselName"      column="vessel_name"      />
        <result property="crewId"          column="crew_id"          />
        <result property="crewName"        column="crew_name"        />
        <result property="applicationNo"   column="application_no"   />
        <result property="applicationType" column="application_type" />
        <result property="title"           column="title"            />
        <result property="applicantName"   column="applicant_name"   />
        <result property="applicantPhone"  column="applicant_phone"  />
        <result property="priority"        column="priority"         />
        <result property="content"         column="content"          />
        <result property="currentStep"     column="current_step"     />
        <result property="progressPercent" column="progress_percent" />
        <result property="status"          column="status"           />
        <result property="submittedTime"   column="submitted_time"   />
        <result property="auditBy"         column="audit_by"         />
        <result property="auditTime"       column="audit_time"       />
        <result property="auditOpinion"    column="audit_opinion"    />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
    </resultMap>

    <sql id="selectApplicationVo">
        select a.application_id, a.tenant_id, t.tenant_name, a.vessel_id, v.vessel_name,
               a.crew_id, c.crew_name, a.application_no, a.application_type, a.title,
               a.applicant_name, a.applicant_phone, a.priority, a.content, a.current_step,
               a.progress_percent, a.status, a.submitted_time, a.audit_by, a.audit_time,
               a.audit_opinion, a.create_by, a.create_time, a.update_by, a.update_time, a.remark
        from sea_business_application a
        left join sea_tenant t on a.tenant_id = t.tenant_id
        left join sea_vessel v on a.vessel_id = v.vessel_id
        left join sea_crew c on a.crew_id = c.crew_id
    </sql>

    <select id="selectApplicationList" parameterType="SeaBusinessApplication" resultMap="SeaBusinessApplicationResult">
        <include refid="selectApplicationVo"/>
        <where>
            <if test="tenantId != null">
                AND a.tenant_id = #{tenantId}
            </if>
            <if test="vesselId != null">
                AND a.vessel_id = #{vesselId}
            </if>
            <if test="crewId != null">
                AND a.crew_id = #{crewId}
            </if>
            <if test="applicationNo != null and applicationNo != ''">
                AND a.application_no like concat('%', #{applicationNo}, '%')
            </if>
            <if test="applicationType != null and applicationType != ''">
                AND a.application_type = #{applicationType}
            </if>
            <if test="title != null and title != ''">
                AND a.title like concat('%', #{title}, '%')
            </if>
            <if test="applicantName != null and applicantName != ''">
                AND a.applicant_name like concat('%', #{applicantName}, '%')
            </if>
            <if test="priority != null and priority != ''">
                AND a.priority = #{priority}
            </if>
            <if test="status != null and status != ''">
                AND a.status = #{status}
            </if>
        </where>
        order by a.application_id desc
    </select>

    <select id="selectApplicationById" parameterType="Long" resultMap="SeaBusinessApplicationResult">
        <include refid="selectApplicationVo"/>
        where a.application_id = #{applicationId}
    </select>

    <select id="checkApplicationNoUnique" parameterType="String" resultMap="SeaBusinessApplicationResult">
        <include refid="selectApplicationVo"/>
        where a.application_no = #{applicationNo} limit 1
    </select>

    <insert id="insertApplication" parameterType="SeaBusinessApplication" useGeneratedKeys="true" keyProperty="applicationId">
        insert into sea_business_application(
            <if test="tenantId != null">tenant_id,</if>
            <if test="vesselId != null">vessel_id,</if>
            <if test="crewId != null">crew_id,</if>
            <if test="applicationNo != null and applicationNo != ''">application_no,</if>
            <if test="applicationType != null and applicationType != ''">application_type,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="applicantName != null and applicantName != ''">applicant_name,</if>
            <if test="applicantPhone != null">applicant_phone,</if>
            <if test="priority != null and priority != ''">priority,</if>
            <if test="content != null">content,</if>
            <if test="currentStep != null and currentStep != ''">current_step,</if>
            <if test="progressPercent != null">progress_percent,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="submittedTime != null">submitted_time,</if>
            <if test="auditBy != null and auditBy != ''">audit_by,</if>
            <if test="auditTime != null">audit_time,</if>
            <if test="auditOpinion != null">audit_opinion,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="tenantId != null">#{tenantId},</if>
            <if test="vesselId != null">#{vesselId},</if>
            <if test="crewId != null">#{crewId},</if>
            <if test="applicationNo != null and applicationNo != ''">#{applicationNo},</if>
            <if test="applicationType != null and applicationType != ''">#{applicationType},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="applicantName != null and applicantName != ''">#{applicantName},</if>
            <if test="applicantPhone != null">#{applicantPhone},</if>
            <if test="priority != null and priority != ''">#{priority},</if>
            <if test="content != null">#{content},</if>
            <if test="currentStep != null and currentStep != ''">#{currentStep},</if>
            <if test="progressPercent != null">#{progressPercent},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="submittedTime != null">#{submittedTime},</if>
            <if test="auditBy != null and auditBy != ''">#{auditBy},</if>
            <if test="auditTime != null">#{auditTime},</if>
            <if test="auditOpinion != null">#{auditOpinion},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateApplication" parameterType="SeaBusinessApplication">
        update sea_business_application
        <set>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="vesselId != null">vessel_id = #{vesselId},</if>
            <if test="crewId != null">crew_id = #{crewId},</if>
            <if test="applicationNo != null and applicationNo != ''">application_no = #{applicationNo},</if>
            <if test="applicationType != null and applicationType != ''">application_type = #{applicationType},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="applicantName != null and applicantName != ''">applicant_name = #{applicantName},</if>
            <if test="applicantPhone != null">applicant_phone = #{applicantPhone},</if>
            <if test="priority != null and priority != ''">priority = #{priority},</if>
            <if test="content != null">content = #{content},</if>
            <if test="currentStep != null and currentStep != ''">current_step = #{currentStep},</if>
            <if test="progressPercent != null">progress_percent = #{progressPercent},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="submittedTime != null">submitted_time = #{submittedTime},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="auditOpinion != null">audit_opinion = #{auditOpinion},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where application_id = #{applicationId}
    </update>

    <delete id="deleteApplicationByIds" parameterType="Long">
        delete from sea_business_application where application_id in
        <foreach collection="array" item="applicationId" open="(" separator="," close=")">
            #{applicationId}
        </foreach>
    </delete>

</mapper>
