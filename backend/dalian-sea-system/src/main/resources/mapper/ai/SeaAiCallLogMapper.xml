<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.daliansea.ai.system.mapper.SeaAiCallLogMapper">

    <resultMap type="SeaAiCallLog" id="SeaAiCallLogResult">
        <id     property="logId"          column="log_id"          />
        <result property="tenantId"       column="tenant_id"       />
        <result property="tenantName"     column="tenant_name"     />
        <result property="scene"          column="scene"           />
        <result property="question"       column="question"        />
        <result property="answer"         column="answer"          />
        <result property="providerName"   column="provider_name"   />
        <result property="modelName"      column="model_name"      />
        <result property="requestTokens"  column="request_tokens"  />
        <result property="responseTokens" column="response_tokens" />
        <result property="totalTokens"    column="total_tokens"    />
        <result property="latencyMs"      column="latency_ms"      />
        <result property="successFlag"    column="success_flag"    />
        <result property="errorMessage"   column="error_message"   />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
    </resultMap>

    <sql id="selectCallLogVo">
        select l.log_id, l.tenant_id, t.tenant_name, l.scene, l.question, l.answer,
               l.provider_name, l.model_name, l.request_tokens, l.response_tokens,
               l.total_tokens, l.latency_ms, l.success_flag, l.error_message,
               l.create_by, l.create_time
        from sea_ai_call_log l
        left join sea_tenant t on l.tenant_id = t.tenant_id
    </sql>

    <select id="selectCallLogList" parameterType="SeaAiCallLog" resultMap="SeaAiCallLogResult">
        <include refid="selectCallLogVo"/>
        <where>
            <if test="tenantId != null">
                AND l.tenant_id = #{tenantId}
            </if>
            <if test="scene != null and scene != ''">
                AND l.scene = #{scene}
            </if>
            <if test="question != null and question != ''">
                AND l.question like concat('%', #{question}, '%')
            </if>
            <if test="providerName != null and providerName != ''">
                AND l.provider_name = #{providerName}
            </if>
            <if test="modelName != null and modelName != ''">
                AND l.model_name like concat('%', #{modelName}, '%')
            </if>
            <if test="successFlag != null and successFlag != ''">
                AND l.success_flag = #{successFlag}
            </if>
        </where>
        order by l.log_id desc
    </select>

    <select id="selectCallLogById" parameterType="Long" resultMap="SeaAiCallLogResult">
        <include refid="selectCallLogVo"/>
        where l.log_id = #{logId}
    </select>

    <insert id="insertCallLog" parameterType="SeaAiCallLog" useGeneratedKeys="true" keyProperty="logId">
        insert into sea_ai_call_log(
            <if test="tenantId != null">tenant_id,</if>
            <if test="scene != null and scene != ''">scene,</if>
            <if test="question != null">question,</if>
            <if test="answer != null">answer,</if>
            <if test="providerName != null and providerName != ''">provider_name,</if>
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="requestTokens != null">request_tokens,</if>
            <if test="responseTokens != null">response_tokens,</if>
            <if test="totalTokens != null">total_tokens,</if>
            <if test="latencyMs != null">latency_ms,</if>
            <if test="successFlag != null and successFlag != ''">success_flag,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="tenantId != null">#{tenantId},</if>
            <if test="scene != null and scene != ''">#{scene},</if>
            <if test="question != null">#{question},</if>
            <if test="answer != null">#{answer},</if>
            <if test="providerName != null and providerName != ''">#{providerName},</if>
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="requestTokens != null">#{requestTokens},</if>
            <if test="responseTokens != null">#{responseTokens},</if>
            <if test="totalTokens != null">#{totalTokens},</if>
            <if test="latencyMs != null">#{latencyMs},</if>
            <if test="successFlag != null and successFlag != ''">#{successFlag},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <delete id="deleteCallLogByIds" parameterType="Long">
        delete from sea_ai_call_log where log_id in
        <foreach collection="array" item="logId" open="(" separator="," close=")">
            #{logId}
        </foreach>
    </delete>

</mapper>
